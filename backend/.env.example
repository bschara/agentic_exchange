# ── Somnia Testnet ──────────────────────────────────────────────────────────────
# Fill these for testnet deployment.
# For local Hardhat dev, see the commented section at the bottom instead.

SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312
SOMNIA_BLOCK_MS=400

# 6 funded Somnia testnet wallets — generate with:
#   node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log(w.privateKey, w.address)"
DEPLOYER_PRIVATE_KEY=0x<your_deployer_key>
MARKET_MAKER_PK=0x<market_maker_key>
MOMENTUM_TRADER_PK=0x<momentum_trader_key>
ARBITRAGE_AGENT_PK=0x<arbitrage_agent_key>
RISK_MANAGER_PK=0x<risk_manager_key>
NOISE_TRADER_PK=0x<noise_trader_key>

# Contract addresses — printed by `npx hardhat run scripts/deploy.js --network somnia`
EXCHANGE_ADDRESS=0x<from_deploy_output>
AGENT_REGISTRY_ADDRESS=0x<from_deploy_output>
TREASURY_ADDRESS=0x<from_deploy_output>
AGENT_COORDINATOR_ADDRESS=0x<from_deploy_output>
AGENT_TOKEN_ADDRESS=0x<from_deploy_output>
QUOTE_TOKEN_ADDRESS=0x<from_deploy_output>

FRONTEND_URL=http://localhost:3000


# ── Local Hardhat dev only ───────────────────────────────────────────────────────
# These are the well-known PUBLIC Hardhat test keys (derived from the "test...junk"
# mnemonic). SAFE for local dev only — NEVER use on testnet or mainnet.
#
# When SOMNIA_RPC_URL points to 127.0.0.1, the backend auto-loads contract
# addresses AND agent PKs from contracts/deployments/somnia-local.json — you
# only need to set the RPC URL and chain ID here.
#
# SOMNIA_RPC_URL=http://127.0.0.1:8545
# SOMNIA_CHAIN_ID=31337
# DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# MARKET_MAKER_PK=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# MOMENTUM_TRADER_PK=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
# ARBITRAGE_AGENT_PK=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6
# RISK_MANAGER_PK=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a
# NOISE_TRADER_PK=0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba
